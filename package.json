{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.obelisk.chronicles",
    "productName": "OBELISK OMNICRON CHRONICLES",
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "public/**/*"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "portable",
      "icon": "public/favicon.png"
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.16",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "phaser": "^3.90.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "styled-components": "^6.3.12",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.16",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "vite": "^7.1.7",
    "wait-on": "^9.0.4"
  }
}
